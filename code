<!DOCTYPE html>
<html>
<head>
    <title>number gusing</title>
</head>
<body>
    <script>
        alert("wellcom to number gusing")

        let secret = Math.floor(Math.random() * 10) + 1

        let guess = prompt("guess the number from 1 to 10")

       if (guess == secret){
        alert("correct!")
       } 
       else{
        alert(`wrong. the number was ${secret}.`)
       }
    </script>
</body>
</html>